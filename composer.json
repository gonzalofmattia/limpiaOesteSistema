{
    "name": "limpia-oeste/abm",
    "description": "Sistema ABM de productos y precios - LIMPIA OESTE",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "dompdf/dompdf": "^2.0",
        "phpoffice/phpspreadsheet": "^2.0 || ^3.0 || ^4.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "scripts": {
        "deploy": "php deploy.php",
        "deploy:dry": "php deploy.php --dry-run",
        "deploy:app": "php deploy.php --only=app",
        "deploy:public": "php deploy.php --only=public",
        "db:export": "php db_export.php",
        "db:import": "php db_import.php"
    }
}

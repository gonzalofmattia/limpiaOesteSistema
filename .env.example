DB_USER=
DB_PASS=

# FTP — cuenta real del hosting (misma que en tu .env local para deploy)
FTP_HOST=a0051423.ferozo.com
FTP_USER=a0051423
FTP_PASS=vowe1@@15sobePE
# Ver DEPLOY_CHECKLIST.md → «Cómo saber FTP_PATH». Valor inicial típico:

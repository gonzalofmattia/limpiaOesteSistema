# =============================================================================
# LIMPIA OESTE — Plantilla .env (servidor producción: sistema.limpiaoeste.com.ar)
# En el servidor: copiar a .env y completar DB_* y FTP_PASS (solo si usás deploy desde PC).
# =============================================================================

APP_ENV=production
APP_DEBUG=false
APP_URL=https://sistema.limpiaoeste.com.ar

# MySQL (Ferozo → Bases de datos → crear base y usuario; copiar nombre de base, usuario y clave)
DB_HOST=localhost
DB_NAME=
DB_USER=
DB_PASS=

# SMTP (DonWeb) — envío de facturas desde el sistema
MAIL_HOST=mail.limpiaoeste.com.ar
MAIL_PORT=465
MAIL_USERNAME=gonzalo@limpiaoeste.com.ar
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=gonzalo@limpiaoeste.com.ar
MAIL_FROM_NAME="Limpia Oeste"
# true = no envía; solo registra en error_log (pruebas locales)
MAIL_PRETEND=false
# Timeout conexión SMTP (segundos)
MAIL_TIMEOUT=30
# Host para EHLO (si vacío, se usa el host de APP_URL)
MAIL_EHLO_HOST=
# 1–4 = log detallado SMTP en error_log (ver vendor/phpmailer SMTP::DEBUG_*). 0 = off
MAIL_DEBUG=0
# En hosting compartido a veces falla verify SSL: probá false solo si el error lo indica
MAIL_SSL_VERIFY_PEER=true

# FTP — cuenta real del hosting (misma que en tu .env local para deploy)
FTP_HOST=a0051423.ferozo.com
FTP_USER=a0051423
FTP_PASS=vowe1@@15sobePE
# Ver DEPLOY_CHECKLIST.md → «Cómo saber FTP_PATH». Valor inicial típico:
FTP_PATH=/public_html/sistema
